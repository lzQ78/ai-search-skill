# AI Search Skill environment template
#
# No single provider key is required.
# Fill the providers you want to use, then run:
#
#   python -m aisearch doctor
#
# Providers without keys are skipped unless noted otherwise.


# ---------------------------------------------------------------------------
# Search providers
# ---------------------------------------------------------------------------

# Optional.
# Tavily is used for general web search, news/status queries, and URL extraction.
# Enables:
# - search provider: tavily
# - fetch provider: tavily
TAVILY_API_KEY=

# Optional.
# Brave is used for broad web search coverage.
# Enables:
# - search provider: brave
BRAVE_API_KEY=

# Optional.
# Exa is used for semantic, technical, academic, and resource discovery.
# Enables:
# - search provider: exa
# - fetch provider: exa
EXA_API_KEY=

# Optional.
# Jina search requires this key.
# Jina fetch can still run without a key through the public reader endpoint.
# Enables:
# - search provider: jina
# - authenticated fetch provider: jina
JINA_API_KEY=

# Optional.
# Perplexity is used only as an AI synthesis lead source.
# Its results are marked ai_synthesis and cannot alone produce high confidence.
# Enables:
# - synthesis/search lead provider: perplexity
PERPLEXITY_API_KEY=


# ---------------------------------------------------------------------------
# Content fetch and extraction providers
# ---------------------------------------------------------------------------

# Optional.
# Firecrawl is used to scrape/fetch original page content.
# Enables:
# - fetch provider: firecrawl
FIRECRAWL_API_KEY=

# Optional.
# MinerU is used as a fallback extractor for high-friction pages and selected
# anti-bot domains when --content-fallback auto|mineru is enabled.
# Enables:
# - fetch fallback provider: mineru
MINERU_API_TOKEN=


# ---------------------------------------------------------------------------
# Optional GitHub thread enrichment
# ---------------------------------------------------------------------------

# Optional.
# Used by thread reference extraction for GitHub issue/PR API calls.
# Without this token, public GitHub API requests are still attempted but may hit
# stricter rate limits.
GITHUB_TOKEN=
# GH_TOKEN is also accepted by the GitHub client.
GH_TOKEN=


# ---------------------------------------------------------------------------
# Runtime controls
# ---------------------------------------------------------------------------

# Optional. Default: 30 seconds.
# HTTP request timeout used by provider clients.
AISEARCH_REQUEST_TIMEOUT=30

# Optional. Default: 4.
# Maximum concurrent URL fetches during research.
AISEARCH_FETCH_CONCURRENCY=4

# Optional. Default: 3.
# Maximum thread-like URLs to fetch when --thread-depth is greater than 0.
AISEARCH_MAX_THREAD_FETCHES=3


# ---------------------------------------------------------------------------
# Optional outbound proxy
# ---------------------------------------------------------------------------

# Optional.
# Configure these when your network needs a local proxy to access the public
# internet and that proxy is not enabled globally for child processes.
# ai-search uses Python/httpx provider clients. These variables give those
# clients an explicit outbound path instead of relying on system/global proxy
# settings from tools such as CC SWITCH.
#
# Example for a local HTTP proxy:
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=http://127.0.0.1:7890
# NO_PROXY=127.0.0.1,localhost
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=127.0.0.1,localhost
